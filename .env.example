# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
# Inside Docker containers use the internal listener:
# KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_TOPIC_RAW=ecommerce-raw
KAFKA_TOPIC_CLEAN=ecommerce-clean
KAFKA_TOPIC_ALERTS=ecommerce-alerts
# Un groupe par composant — évite les rebalancing croisés
KAFKA_CONSUMER_GROUP_CONSUMER=etl-consumer
KAFKA_CONSUMER_GROUP_PIPELINE=etl-pipeline
KAFKA_CONSUMER_GROUP_DETECTOR=cart-abandonment

# Schema paths (relative to project root)
SCHEMA_RAW_PATH=schemas/event_raw.avsc
SCHEMA_CLEAN_PATH=schemas/event_clean.avsc
SCHEMA_ALERT_PATH=schemas/cart_abandonment_alert.avsc

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=tpdb
POSTGRES_USER=tpuser
POSTGRES_PASSWORD=tppassword

# Elasticsearch
ES_HOST=localhost
ES_PORT=9200
ES_INDEX=ecommerce-events

# App
LOG_LEVEL=INFO
DATA_PATH=data/sample/sample_data.jsonl
CHUNK_SIZE=10000
PIPELINE_BATCH_SIZE=500

# Cart abandonment
ABANDONMENT_THRESHOLD=0.8
